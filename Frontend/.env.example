# =============================================================================
# Frontend environment configuration template
# =============================================================================
# Copy this file to `.env` and override values as needed.

# -----------------------------------------------------------------------------
# Flask
# -----------------------------------------------------------------------------
FLASK_APP=web:create_app
FLASK_ENV=development
FLASK_RUN_PORT=3000               # so `flask run` doesn't need --port
SECRET_KEY=change-me              # replace before any non-local deployment

# -----------------------------------------------------------------------------
# Runtime (read by web/config.py)
# -----------------------------------------------------------------------------
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=3000                     # 5000 collides with macOS AirPlay; can be reverted once containerized
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Backend integration
# In docker-compose this is overridden to http://api:8000/api/v1.
# -----------------------------------------------------------------------------
BACKEND_API_URL=http://localhost:8000/api/v1

# -----------------------------------------------------------------------------
# Upload limits (UI hint; enforced server-side)
# -----------------------------------------------------------------------------
MAX_UPLOAD_SIZE_MB=10
