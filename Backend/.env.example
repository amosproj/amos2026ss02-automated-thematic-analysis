# =============================================================================
# Environment Configuration Template
# =============================================================================
# Copy this file to `.env` and fill in your values.

# -----------------------------------------------------------------------------
# Database
#
# Local development
#   Docker Compose maps the Postgres container port to 5433 on the host,
#   so use localhost:5433 here.
#
# Docker / CI (backend running inside a container):
#   The docker-compose.yml overrides DATABASE_URL automatically to use the
#   internal `db:5432` address, so you don't need to change this file.
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/appdb

# -----------------------------------------------------------------------------
# CORS
# JSON array of origins the browser is allowed to call from.
# -----------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=["http://localhost:3000"]

# -----------------------------------------------------------------------------
# LLM
# SELECTED_API is the DEFAULT provider used until one is chosen in the UI.
# The active provider can be switched live from the Home page (LLM Provider
# card); that choice is stored server-side and read by every AI task at run
# start. Configure the key for any provider you might select.
# Base URLs and model names have sensible defaults in config.py — only override
# them here if you need to point to a different endpoint or use a different model.
#
# SELECTED_API=FAU       → defaults to LLM_API_KEY_FAU + NHR@FAU gateway
# SELECTED_API=ACADEMIC  → defaults to LLM_API_KEY    + Academic Cloud
# -----------------------------------------------------------------------------
SELECTED_API=FAU

# Embeddings follow the same selected provider. They compare code
# labels/descriptions by meaning during codebook generation and consolidation.
# Override these only when the selected provider supports the requested
# OpenAI-compatible /embeddings model.

# NHR@FAU — required: your API key (https://hpc.fau.de/request-llm-api-key/)
LLM_API_KEY_FAU=<your_nhr_fau_key_here>
# LLM_MODEL_FAU=gpt-oss-120b
# EMBEDDING_MODEL_FAU=intfloat/multilingual-e5-large

# Academic Cloud — required to select the Academic Cloud provider in the UI
LLM_API_KEY=<your_academic_cloud_key_here>
# LLM_BASE_URL=https://chat-ai.academiccloud.de/v1
# LLM_MODEL=gemma-4-31b-it
# EMBEDDING_MODEL=multilingual-e5-large-instruct

# Example: route the ACADEMIC slot through OpenAI instead. The UI label remains
# "Academic Cloud" unless a first-class OpenAI provider is added in code.
# SELECTED_API=ACADEMIC
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=<your_openai_api_key>
# LLM_MODEL=gpt-4.1-mini
# EMBEDDING_MODEL=text-embedding-3-large
